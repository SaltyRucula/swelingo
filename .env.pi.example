# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Create a tunnel in the Cloudflare Zero Trust dashboard:
#   Networks → Tunnels → Create a tunnel → Cloudflared → (name it) → copy the token.
# Then add a Public Hostname for the tunnel that routes your domain to:
#   Service:  HTTP  →  web:80
TUNNEL_TOKEN=<your_cloudflare_tunnel_token>

# ── Public URLs (served via Cloudflare — always https, no port number) ────────
# Use the domain you attached to the tunnel. Web and API share one origin
# because nginx proxies the API paths internally, so all three are identical.
EXPO_PUBLIC_API_URL=https://yourdomain.com
API_BASE_URL=https://yourdomain.com
WEB_URL=https://yourdomain.com

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# OAuth App: https://github.com/settings/developers
# Set the Authorization callback URL to:
#   https://yourdomain.com/auth/github/callback
GITHUB_CLIENT_ID=<your_github_client_id>
GITHUB_CLIENT_SECRET=<your_github_client_secret>

# ── JWT ──────────────────────────────────────────────────────────────────────
# Long random string used to sign JWTs. Generate with:
#   openssl rand -hex 64
JWT_SECRET=<long_random_string>

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Password for the postgres user. Change before deploying.
POSTGRES_PASSWORD=changeme
