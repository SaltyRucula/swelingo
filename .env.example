# ── Expo / Web ─────────────────────────────────────────────────────────────────
# URL of the deployed Rust API — used by the Expo web app at build time.
# Replace with your DigitalOcean Droplet's public IP or domain.
#
# Examples:
#   EXPO_PUBLIC_API_URL=http://165.22.100.42:3001
#   EXPO_PUBLIC_API_URL=https://api.yourdomain.com
#
EXPO_PUBLIC_API_URL=http://<YOUR_DROPLET_IP>:3001

# ── GitHub OAuth ───────────────────────────────────────────────────────────────
# Create an OAuth App at: https://github.com/settings/developers
# Set Authorization callback URL to: http://<YOUR_DROPLET_IP>:3001/auth/github/callback
#
GITHUB_CLIENT_ID=<your_github_client_id>
GITHUB_CLIENT_SECRET=<your_github_client_secret>

# ── JWT ────────────────────────────────────────────────────────────────────────
# Long random string used to sign JWTs. Generate with:
#   openssl rand -hex 64
#
JWT_SECRET=<long_random_string>

# ── Web URL (no trailing slash) ────────────────────────────────────────────────
# The public URL of the web app — used by the API to redirect after OAuth.
#
WEB_URL=http://<YOUR_DROPLET_IP>

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# Password for the postgres user. Change before deploying.
#
POSTGRES_PASSWORD=changeme

